{
  "manifest_version": 3,
  "name": "딸깍분석 LITE",
  "version": "2.0.0",
  "description": "페이지 분석 + 검색 기반 AI 상품 분석 (Lite 버전 - 저비용)",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://*/*", "http://*/*"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [{
    "resources": ["panel.html", "config.js", "panel.js", "review.js"],
    "matches": ["https://*/*", "http://*/*"]
  }]
}
